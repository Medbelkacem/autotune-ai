# ─── Core ────────────────────────────────────────────────
APP_ENV=local
APP_NAME=autotune-ai
LOG_LEVEL=INFO
SECRET_KEY=change-me-32-bytes-minimum-please-rotate

# ─── Postgres (OLTP) ─────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=autotune
POSTGRES_PASSWORD=autotune
POSTGRES_DB=autotune
DATABASE_URL=postgresql+asyncpg://autotune:autotune@postgres:5432/autotune

# ─── TimescaleDB (telemetry) ─────────────────────────────
TIMESCALE_URL=postgresql+asyncpg://autotune:autotune@timescaledb:5432/telemetry

# ─── Redis ───────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
RATE_LIMIT_REDIS_URL=redis://redis:6379/1

# ─── RabbitMQ + Kafka ────────────────────────────────────
RABBITMQ_URL=amqp://autotune:autotune@rabbitmq:5672//
CELERY_BROKER_URL=amqp://autotune:autotune@rabbitmq:5672//
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ─── Vector + KG ─────────────────────────────────────────
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=autotune-graph

# ─── Object store ────────────────────────────────────────
S3_ENDPOINT=http://minio:9000
S3_BUCKET=autotune-artifacts
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio12345
S3_REGION=us-east-1

# ─── Anthropic / Claude ──────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_REASONING=claude-opus-4-8
ANTHROPIC_MODEL_ANALYSIS=claude-sonnet-4-6
ANTHROPIC_MODEL_ROUTING=claude-haiku-4-5-20251001

# ─── Embeddings ──────────────────────────────────────────
EMBED_PROVIDER=voyage
VOYAGE_API_KEY=
EMBED_MODEL=voyage-3

# ─── Auth ────────────────────────────────────────────────
JWT_ISSUER=https://auth.autotune.ai
JWT_AUDIENCE=autotune-api
JWT_ACCESS_TTL_SECONDS=300
JWT_REFRESH_TTL_SECONDS=2592000
PASSWORD_PEPPER=change-me-too

# ─── OIDC (optional) ─────────────────────────────────────
OIDC_DISCOVERY_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# ─── Billing ─────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Observability ───────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
SENTRY_DSN=

# ─── Web ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-web

# ─── Mobile ──────────────────────────────────────────────
EXPO_PUBLIC_API_URL=http://localhost:8000
