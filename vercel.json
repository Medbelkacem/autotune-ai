  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm --filter @autotune/web... build",
  "installCommand": "pnpm install --frozen-lockfile || pnpm install",
  "outputDirectory": "apps/web/.next",
  "framework": "nextjs",
  "regions": ["iad1"],
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  }
}
